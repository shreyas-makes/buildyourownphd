{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "pipeline": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "build/**", ".expo/**"],
      "env": ["NODE_ENV", "DATABASE_URL", "NEXTAUTH_SECRET", "NEXTAUTH_URL", "SUPABASE_URL", "SUPABASE_ANON_KEY"]
    },
    "build:android": {
      "dependsOn": ["^build"],
      "outputs": ["build/**", "*.apk", "*.aab"],
      "env": ["EXPO_PUBLIC_API_URL"]
    },
    "build:ios": {
      "dependsOn": ["^build"],
      "outputs": ["build/**", "*.ipa"],
      "env": ["EXPO_PUBLIC_API_URL"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["NODE_ENV", "PORT", "DATABASE_URL", "SUPABASE_URL", "SUPABASE_ANON_KEY"]
    },
    "start": {
      "cache": false,
      "persistent": true,
      "env": ["NODE_ENV", "PORT", "EXPO_PUBLIC_API_URL"]
    },
    "start:dev": {
      "cache": false,
      "persistent": true,
      "env": ["NODE_ENV", "PORT", "DATABASE_URL"]
    },
    "start:prod": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true,
      "env": ["NODE_ENV", "PORT", "DATABASE_URL"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "lint:fix": {
      "dependsOn": ["^lint:fix"],
      "outputs": []
    },
    "type-check": {
      "dependsOn": ["^type-check"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "inputs": ["src/**/*.tsx", "src/**/*.ts", "test/**/*.ts", "test/**/*.tsx", "**/*.spec.ts", "**/*.test.ts"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "outputs": [],
      "inputs": ["test/**/*.ts", "e2e/**/*.ts"]
    },
    "clean": {
      "cache": false
    }
  }
} 